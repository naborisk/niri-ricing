layout {
    gaps 16
    center-focused-column "never"

    // Required for Noctalia to draw the wallpaper underneath windows.
    background-color "transparent"

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    focus-ring {
        on
        width 2
    }

    struts {}
}
