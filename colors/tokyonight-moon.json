{
  "$schema": "https://json.schemastore.org/base",
  "name": "tokyonight-moon",
  "description": "Tokyonight Moon palette with deuteranomaly-aware semantic mapping. Source palette from folke/tokyonight.nvim.",

  "base": {
    "bg":            "#222436",
    "bg_dark":       "#1e2030",
    "bg_dark1":      "#191b29",
    "bg_highlight":  "#2f334d",
    "terminal_black":"#444a73",
    "fg":            "#c8d3f5",
    "fg_dark":       "#828bb8",
    "fg_gutter":     "#3b4261",
    "dark3":         "#545c7e",
    "comment":       "#636da6",
    "dark5":         "#737aa2",

    "blue0":         "#3e68d7",
    "blue":          "#82aaff",
    "blue1":         "#65bcff",
    "blue2":         "#0db9d7",
    "blue5":         "#89ddff",
    "blue6":         "#b4f9f8",
    "blue7":         "#394b70",
    "cyan":          "#86e1fc",

    "magenta":       "#c099ff",
    "magenta2":      "#ff007c",
    "purple":        "#fca7ea",

    "orange":        "#ff966c",
    "yellow":        "#ffc777",
    "green":         "#c3e88d",
    "green1":        "#4fd6be",
    "green2":        "#41a6b5",
    "teal":          "#4fd6be",

    "red":           "#ff757f",
    "red1":          "#c53b53"
  },

  "_semantic_note": "Mapped for deuteranomaly. Blue<->red is on a safe color-blindness axis; red<->green is NOT. Never use red+green for semantic pairs (success/failure, accept/reject, on/off). Use these tokens in UI surfaces (buttons, notifications, status icons), NOT in syntax highlighting.",
  "semantic": {
    "success":      "#82aaff",
    "success_alt":  "#86e1fc",
    "warning":      "#ffc777",
    "danger":       "#ff757f",
    "info":         "#c099ff",
    "muted":        "#828bb8",
    "accent":       "#82aaff"
  },

  "ui": {
    "bg":            "#222436",
    "bg_panel":      "#1e2030",
    "bg_overlay":    "#2f334d",
    "border":        "#3b4261",
    "border_focus":  "#82aaff",
    "fg":            "#c8d3f5",
    "fg_dim":        "#828bb8",
    "selection":     "#2d3f76",
    "scrollbar":     "#444a73",
    "shadow":        "#0d0e15"
  },

  "terminal": {
    "background":    "#222436",
    "foreground":    "#c8d3f5",
    "cursor":        "#c8d3f5",
    "selection_bg":  "#2d3f76",
    "selection_fg":  "#c8d3f5",

    "black":         "#1b1d2b",
    "red":           "#ff757f",
    "green":         "#c3e88d",
    "yellow":        "#ffc777",
    "blue":          "#82aaff",
    "magenta":       "#c099ff",
    "cyan":          "#86e1fc",
    "white":         "#828bb8",

    "bright_black":  "#444a73",
    "bright_red":    "#ff8d94",
    "bright_green":  "#c7fb6d",
    "bright_yellow": "#ffd8ab",
    "bright_blue":   "#9ab8ff",
    "bright_magenta":"#caabff",
    "bright_cyan":   "#b2ebff",
    "bright_white":  "#c8d3f5"
  },

  "wallpaper_tints": {
    "_note": "Suggested overlay tints when matching a wallpaper to this palette. Apply at low opacity (5-15%) over the wallpaper if it doesn't blend.",
    "cool":  "#1e2030",
    "warm":  "#2d2640",
    "deep":  "#191b29"
  }
}
